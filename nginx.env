# ============================================================
# Hostnames reales de los servicios desplegados en Render (sin
# protocolo, sin barra final). Usados por envsubst en docker-compose.yml
# para generar nginx.conf desde nginx.conf.template.
#
# IMPORTANTE: verifica estos valores contra el dashboard de Render
# (cada servicio muestra su URL pública en la pestaña "Settings").
# RENDER_API_1 se tomó de react-client/.env (URL real con sufijo -zvn6).
# RENDER_API_2 es el nombre del blueprint en api-rest/render.yaml;
# confírmalo si Render le asignó un sufijo distinto.
# ============================================================
RENDER_API_1=techstore-api-1-zvn6.onrender.com
RENDER_API_2=techstore-api-2.onrender.com
