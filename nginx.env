# ============================================================
# TECHSTORE 360 – Variables del balanceador Nginx
# Copiá este archivo como referencia; los valores reales van
# en las variables de entorno del servidor / Render dashboard.
# ============================================================

# ── API REST (Render) ─────────────────────────────────────────
RENDER_API_1=techstore-api-1-zvn6.onrender.com
RENDER_API_2=techstore-api-2.onrender.com

# ── WordPress VMs ─────────────────────────────────────────────
# Ponés las IPs privadas (o públicas) de tus máquinas virtuales
WP_VM1=192.168.1.10
WP_VM2=192.168.1.11
WP_PORT=80          # Puerto en el que corre WordPress dentro de cada VM
WP_LB_PORT=8080     # Puerto público que expone el balanceador para WordPress

# ── Joomla VMs ────────────────────────────────────────────────
JOOMLA_VM1=192.168.1.20
JOOMLA_VM2=192.168.1.21
JOOMLA_PORT=80      # Puerto en el que corre Joomla dentro de cada VM
JOOMLA_LB_PORT=8088 # Puerto público que expone el balanceador para Joomla

# ── Keepalived (referencia — se usa en keepalived/*.conf) ─────
# KEEPALIVED_VIP=192.168.1.100     # IP virtual flotante (VIP)
# KEEPALIVED_INTERFACE=eth0         # Interfaz de red de las VMs del LB
# KEEPALIVED_MASTER_IP=192.168.1.50 # IP real del nodo MASTER
# KEEPALIVED_BACKUP_IP=192.168.1.51 # IP real del nodo BACKUP
# KEEPALIVED_PASSWORD=techstore360  # Contraseña VRRP (cámbiala)
